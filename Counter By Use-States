import { useState } from "react";
function App() {
  const [count,setCount] = useState(0);
  function inc() {
    setCount(x => x + 1);
  }
  function dec() {
    setCount(x => x - 1);
  }
  function reset() {
    setCount(x => x = 0);
  }
  return(
    <>
    <h1>Counter App</h1>
    <h2>{count}</h2>
    <button onClick={inc}>+</button>
    <button onClick={dec}>-</button>
    <button onClick={reset}>Reset</button>
    </>
  )
}
export default App;
